# -------------------- Project-Specific --------------------
# Components staged for future Eye_lean versions (Graphyte GUI for v2.0,
# anything else researchers move into a future/<component>/ subtree).
# Not part of the v1.0 public release.
future/

# Internal development docs (release checklists, planning notes — not for public repo)
INTERNAL/
RELEASE.md
PUBLISHING_WALKTHROUGH.md

# Per-session release-progress tracker maintained by Claude across sessions
.claude_progress/

# Claude AI metadata
.claude/

# Log files
*.log

# Temporary files
.utmp/

# 3D models — re-imported per recording, not source-controlled
*.fbx
*.fbx.meta

# Microsoft Rocketbox avatars — researcher-side install (12 GB).
# See docs/SKELETON_AGENTS.md for setup instructions.
Eye_lean_Unity_Project/Eye_lean/Assets/RocketBox/
Eye_lean_Unity_Project/Eye_lean/Assets/RocketBox.meta
